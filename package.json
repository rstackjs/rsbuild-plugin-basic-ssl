{
  "name": "@rsbuild/plugin-basic-ssl",
  "version": "1.2.3",
  "repository": "https://github.com/rstackjs/rsbuild-plugin-basic-ssl",
  "homepage": "https://github.com/rstackjs/rsbuild-plugin-basic-ssl#readme",
  "bugs": {
    "url": "https://github.com/rstackjs/rsbuild-plugin-basic-ssl/issues"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib",
    "dev": "rslib -w",
    "lint": "rslint && prettier -c .",
    "lint:write": "rslint --fix && prettier -w .",
    "prepare": "simple-git-hooks",
    "test": "rstest",
    "bump": "pnpx bumpp"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run lint:write"
  },
  "dependencies": {
    "selfsigned": "^3.0.1"
  },
  "devDependencies": {
    "@rsbuild/core": "2.1.2",
    "@rslib/core": "^0.23.1",
    "@rslint/core": "^0.6.4",
    "@rstest/core": "^0.11.1",
    "@rstest/playwright": "^0.11.1",
    "@types/node": "^24.13.2",
    "playwright": "^1.61.1",
    "prettier": "^3.9.4",
    "simple-git-hooks": "^2.13.1",
    "typescript": "7.0.2"
  },
  "peerDependencies": {
    "@rsbuild/core": "^1.0.0 || ^2.0.0"
  },
  "peerDependenciesMeta": {
    "@rsbuild/core": {
      "optional": true
    }
  },
  "packageManager": "pnpm@11.9.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
